{
  "name": "osm-noticeboard",
  "version": "0.0.0",
  "description": "Basic single-page kiosk noticeboard for OSM",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "nodemon app.js",
    "test": "node --test tests/*.js",
    "update-version": "node scripts/update-version.js"
  },
  "nodemonConfig": {
    "ignore": [
      "logs/*",
      "public/",
      "cache/*",
      "*.test.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbarnwell/osm-noticeboard.git"
  },
  "author": "Neil Barnwell",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nbarnwell/osm-noticeboard/issues"
  },
  "homepage": "https://github.com/nbarnwell/osm-noticeboard#readme",
  "dependencies": {
    "axios": "^1.7.7",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.1",
    "luxon": "^3.7.2",
    "node-fetch": "^3.3.2",
    "qs": "^6.13.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "overrides": {
    "tar": "^7.5.7"
  }
}
